{
  "name": "@succinctlabs/react-native-zcam1-capture",
  "version": "0.1.24",
  "description": "ZCAM1 Capture SDK",
  "main": "./lib/module/index.js",
  "codegenConfig": {
    "name": "Zcam1SdkSpec",
    "type": "modules",
    "jsSrcsDir": "src"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/succinctlabs/zcam1-sdk.git"
  },
  "author": "leruaa",
  "license": "MIT",
  "homepage": "https://github.com/succinctlabs/zcam1-sdk#readme",
  "devDependencies": {
    "@react-native/babel-preset": "0.81.1",
    "@types/react": "^19.1.0",
    "react-native-builder-bob": "^0.40.17",
    "typescript": "^5.9.3"
  },
  "create-react-native-library": {
    "languages": "kotlin-objc",
    "type": "turbo-module",
    "version": "0.54.8"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@pagopa/io-react-native-integrity": "^0.3.2",
    "@scure/base": "^2.0.0",
    "@succinctlabs/react-native-zcam1-c2pa": "^0.1.9",
    "@succinctlabs/react-native-zcam1-common": "^0.1.6",
    "react-native-encrypted-storage": "^4.0.0",
    "react-native-file-access": "^3.2.0"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-native": ">=0.81"
  },
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./lib/typescript/src/index.d.ts",
  "scripts": {
    "build": "bob build",
    "prepack": "npm run build"
  },
  "files": [
    "src",
    "lib",
    "ios",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "Zcam1Sdk.podspec",
    "README.md",
    "turbo.json"
  ],
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ]
}

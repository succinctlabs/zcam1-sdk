{
  "name": "@succinctlabs/react-native-zcam1-capture",
  "version": "0.2.71",
  "description": "ZCAM1 Capture SDK",
  "main": "./lib/module/index.js",
  "codegenConfig": {
    "name": "Zcam1SdkSpec",
    "type": "modules",
    "jsSrcsDir": "src"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/succinctlabs/zcam1-sdk.git"
  },
  "author": "leruaa",
  "license": "MIT",
  "homepage": "https://github.com/succinctlabs/zcam1-sdk#readme",
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.18.0",
    "@react-native/babel-preset": "0.81.1",
    "@types/react": "^19.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.4.2",
    "react-native-builder-bob": "^0.40.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.21.0"
  },
  "create-react-native-library": {
    "languages": "kotlin-objc",
    "type": "turbo-module",
    "version": "0.54.8"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@pagopa/io-react-native-integrity": "^0.3.2",
    "@scure/base": "^2.0.0",
    "@succinctlabs/react-native-zcam1-c2pa": "^0.2.4",
    "@succinctlabs/react-native-zcam1-capture": "file:.yalc/@succinctlabs/react-native-zcam1-capture",
    "@succinctlabs/react-native-zcam1-common": "^0.2.2",
    "jail-monkey": "^2.8.4",
    "react-native-encrypted-storage": "^4.0.0",
    "react-native-file-access": "^3.2.0"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-native": ">=0.81"
  },
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./lib/typescript/src/index.d.ts",
  "scripts": {
    "build": "bob build",
    "prepack": "npm run build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "Zcam1Sdk.podspec",
    "README.md",
    "turbo.json"
  ],
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ]
}

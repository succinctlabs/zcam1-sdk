{
  "name": "@succinctlabs/react-native-zcam1-common",
  "version": "0.2.1",
  "description": "ZCAM1 SDK low level primitives",
  "main": "./lib/module/index.js",
  "scripts": {
    "build": "bob build",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/succinctlabs/zcam1-sdk.git"
  },
  "author": "leruaa",
  "license": "MIT",
  "devDependencies": {
    "react-native-builder-bob": "^0.40.17",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@pagopa/io-react-native-crypto": "^1.2.4",
    "@scure/base": "^2.0.0",
    "cross-fetch": "^4.1.0"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./lib/typescript/src/index.d.ts",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ]
}

ing) {\\n    return (\\n      \\n        \\n        Initializing prover...\\n      \\n    );\\n  }\\n \\n  return (\\n    \\n      \\n      {isProving &amp;&amp; (\\n        \\n          \\n          Generating proof... This may take a few seconds.\\n        \\n      )}\\n      {result &amp;&amp; {result}}\\n    \\n  );\\n}\\n \\nconst styles = StyleSheet.create({\\n  container: { flex: 1, padding: 16 },\\n  centered: { flex: 1, justifyContent: &quot;center&quot;, alignItems: &quot;center&quot; },\\n  status: { marginTop: 16, alignItems: &quot;center&quot; },\\n  result: { marginTop: 16, textAlign: &quot;center&quot; },\\n});\\n\",\"title\":\"Complete Example\",\"titles\":[\"Prove SDK\"]},{\"href\":\"/sdk/prove#using-with-picker\",\"html\":\"\\n<p>Combine with <code>ZImagePicker</code> to show which photos need proving:</p>\\n<pre class=\\\"shiki shiki-themes github-light github-dark-dimmed\\\" style=\\\"background-color:#fff;--shiki-dark-bg:#22272e;color:#24292e;--shiki-dark:#adbac7\\\" tabindex=\\\"0\\\"><code><span class=\\\"line\\\" data-empty-line=\\\"true\\\"> </span>\\n<span class=\\\"line\\\" data-empty-line=\\\"true\\\"> </span>\\n<span class=\\\"line\\\" data-empty-line=\\\"true\\\"> </span>\\n<span class=\\\"line\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">function</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\"> PickerScreen</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">() {</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">  const</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> { </span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\">provingClient</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> } </span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">=</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\"> useProver</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">();</span></span>\\n<span class=\\\"line\\
\"color:#E36209;--shiki-dark:#F69D50\\\"> ready</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">!</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">          )}</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">        </span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">      )}</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">    </span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">  );</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">}</span></span></code></pre>\\n\",\"id\":\"docs/pages/sdk/prove.mdx#two-step-proof-generation-recommended-for-better-ux\",\"isPage\":false,\"text\":\"\\nFor better user experience, use the two-step approach to show progress:\\n \\n \\nfunction ProveWithProgress({ photoUri }: { photoUri: string }) {\\n  const { provingClient } = useProver();\\n  const [requestId, setRequestId] = useState&lt;string | null&gt;(null);\\n  const { proof, fulfillementStatus } = useProofRequestStatus(requestId);\\n \\n  const handleProve = async () =&gt; {\\n    if (!provingClient) return;\\n    \\n    // Step 1: Request proof\\n    const id = await provingClient.requestProof(photoUri);\\n    setRequestId(id);\\n  };\\n \\n  useEffect(() =&gt; {\\n    // Step 2: When proof is ready, embed it\\n    if (proof &amp;&amp; requestId) {\\n      provingClient.embedProof(photoUri, proof).then((provenPath) =&gt; {\\n        console.log(&quot;Proof embedded:&quot;, provenPath);\\n      });\\n    }\\n  }, [proof, requestId]);\\n \\n  return (\\n    \\n      {!requestId &amp;&amp; (\\n        \\n      )}\\n      {requestId &amp;&amp; (\\n        \\n          Status: {fulfillementStatus}\\n          {fulfillementStatus === FulfillmentStatus.Fulfilled &amp;&amp; (\\n            Proof ready!\\n          )}\\n        \\n      )}\\n    \\n  );\\n}\\n\",\"title\":\"Two-Step Proof Generation (Recommended for Better UX)\",\"titles\":[\"Prove SDK\"]},{\"href\":\"/sdk/prove#notes\",\"html\":\"\\n<ul>\\n<li>Proof generation requires network access to the prover backend</li>\\n<li>The input photo must have a <code>succinct.bindings</code> assertion (created by the Capture SDK)</li>\\n<li>Proof generation typically takes a few seconds</li>\\n<li>The original photo is not modified; a new file is created with the embedded proof</li>\\n<li>Use <code>waitAndEmbedProof()</code> for simplicity, or <code>requestProof()</code> + <code>useProofRequestStatus()</code> for better UX with progress tracking</li>\\n</ul>\",\"id\":\"docs/pages/sdk/prove.mdx#notes\",\"isPage\":false,\"text\":\"\\n\\nProof generation requires network access to the prover backend\\nThe input photo must have a succinct.bindings assertion (created by the Capture SDK)\\nProof generation typically takes a few seconds\\nThe original photo is not modified; a new file is created with the embedded proof\\nUse waitAndEmbedProof() for simplicity, or requestProof() + useProofRequestStatus() for better UX with progress tracking\\n\",\"title\":\"Notes\",\"titles\":[\"Prove SDK\"]}]}}"

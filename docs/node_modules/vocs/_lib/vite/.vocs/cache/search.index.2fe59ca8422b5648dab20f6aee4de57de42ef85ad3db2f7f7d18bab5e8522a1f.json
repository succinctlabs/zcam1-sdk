</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\"> =</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\"> new</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\"> VerifiableFile</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">(uri);</span></span>\\n<span class=\\\"line\\\" data-empty-line=\\\"true\\\"> </span>\\n<span class=\\\"line\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">    if</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> (</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">!</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">file.</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">verifyHash</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">()) {</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">      return</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> { status: </span><span style=\\\"color:#032F62;--shiki-dark:#96D0FF\\\">&quot;invalid_hash&quot;</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> };</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">    }</span></span>\\n<span class=\\\"line\\\" data-empty-line=\\\"true\\\"> </span>\\n<span class=\\\"line\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">    if</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> (</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">!</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">file.</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">verifyProof</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">()) {</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">      return</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> { status: </span><span style=\\\"color:#032F62;--shiki-dark:#96D0FF\\\">&quot;invalid_proof&quot;</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> };</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">    }</span></span>\\n<span class=\\\"line\\\" data-empty-line=\\\"true\\\"> </span>\\n<span class=\\\"line\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">    return</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> { status: </span><span style=\\\"color:#032F62;--shiki-dark:#96D0FF\\\">&quot;authentic&quot;</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> };</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">  } </span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">catch</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> (</span><span style=\\\"color:#E36209;--shiki-dark:#F69D50\\\">error</span><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">:</span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\"> any</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">) {</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">    if</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> (error.message?.</span><span style=\\\"color:#6F42C1;--shiki-dark:#DCBDFB\\\">includes</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">(</span><span style=\\\"color:#032F62;--shiki-dark:#96D0FF\\\">&quot;no manifest&quot;</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">)) {</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">      return</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> { status: </span><span style=\\\"color:#032F62;--shiki-dark:#96D0FF\\\">&quot;no_manifest&quot;</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> };</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">    }</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">    return</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> { status: </span><span style=\\\"color:#032F62;--shiki-dark:#96D0FF\\\">&quot;error&quot;</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">, message: error.message };</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">  }</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">}</span></span></code></pre>\\n\",\"id\":\"docs/pages/sdk/verify.mdx#verification-helper\",\"isPage\":false,\"text\":\"\\nCreate a reusable verification function:\\n \\n \\n \\n  | { status: &quot;authentic&quot; }\\n  | { status: &quot;invalid_hash&quot; }\\n  | { status: &quot;invalid_proof&quot; }\\n  | { status: &quot;no_manifest&quot; }\\n  | { status: &quot;error&quot;; message: string };\\n \\n \\n  try {\\n    const file = new VerifiableFile(uri);\\n \\n    if (!file.verifyHash()) {\\n      return { status: &quot;invalid_hash&quot; };\\n    }\\n \\n    if (!file.verifyProof()) {\\n      return { status: &quot;invalid_proof&quot; };\\n    }\\n \\n    return { status: &quot;authentic&quot; };\\n  } catch (error: any) {\\n    if (error.message?.includes(&quot;no manifest&quot;)) {\\n      return { status: &quot;no_manifest&quot; };\\n    }\\n    return { status: &quot;error&quot;, message: error.message };\\n  }\\n}\\n\",\"title\":\"Verification Helper\",\"titles\":[\"Verify SDK\"]},{\"href\":\"/sdk/verify#what-verification-checks\",\"html\":\"\\n<table><thead><tr><th>Check</th><th>What It Validates</th><th>Use Case</th></tr></thead><tbody><tr><td><code>verifyHash()</code></td><td>Photo bytes match the SHA-256 hash in the C2PA manifest</td><td>Always use this first to check file integrity</td></tr><tr><td><code>verifyBindings()</code></td><td>Apple App Attest signature is valid and corresponds to the photo hash</td><td>For photos with <code>succinct.bindings</code> (before proof generation)</td></tr><tr><td><code>verifyProof()</code></td><td>ZK proof is valid and chains to the Apple Root CA</td><td>For photos with <code>succinct.proof</code> (after proof generation)</td></tr></tbody></table>\\n<strong>Verification Flow:</strong>\\n<p>For photos with <code>succinct.bindings</code>:</p>\\n<ol>\\n<li>Call <code>verifyHash()</code> to check file integrity</li>\\n<li>Call <code>verifyBindings()</code> to verify the Apple App Attest signature</li>\\n</ol>\\n<p>For photos with <code>succinct.proof</code>:</p>\\n<ol>\\n<li>Call <code>verifyHash()</code> to check file integrity</li>\\n<li>Call <code>verifyProof()</code> to verify the ZK proof</li>\\n</ol>\\n<p>Both hash and bindings/proof checks must pass for a photo to be considered authentic.</p>\\n\",\"id\":\"docs/pages/sdk/verify.mdx#what-verification-checks\",\"isPage\":false,\"text\":\"\\nCheckWhat It ValidatesUse CaseverifyHash()Photo bytes match the SHA-256 hash in the C2PA manifestAlways use this first to check file integrityverifyBindings()Apple App Attest signature is valid and corresponds to the photo hashFor photos with succinct.bindings (before proof generation)verifyProof()ZK proof is valid and chains to the Apple Root CAFor photos with succinct.proof (after proof generation)\\nVerification Flow:\\nFor photos with succinct.bindings:\\n\\nCall verifyHash() to check file integrity\\nCall verifyBindings() to verify the Apple App Attest signature\\n\\nFor photos with succinct.proof:\\n\\nCall verifyHash() to check file integrity\\nCall verifyProof() to verify the ZK proof\\n\\nBoth hash and bindings/proof checks must pass for a photo to be considered authentic.\\n\",\"title\":\"What Verification Checks\",\"titles\":[\"Verify SDK\"]},{\"href\":\"/sdk/verify#notes\",\"html\":\"\\n<ul>\\n<li>Verification is performed locally—no network required</li>\\n<li>Use <code>verifyBindings()</code> for photos with <code>succinct.bindings</code> (before proof generation)</li>\\n<li>Use <code>verifyProof()</code> for photos with <code>succinct.proof</code> (after proof generation)</li>\\n<li>Photos with only <code>succinct.bindings</code> will fail <code>verifyProof()</code> (they haven&#x27;t been proven yet)</li>\\n<li>Photos with <code>succinct.proof</code> can use either verification method, but <code>verifyProof()</code> provides stronger guarantees</li>\\n<li>The Apple Root CA is pinned in the SDK; proofs must chain to this root</li>\\n<li><code>captureMetadata()</code> provides access to device and camera settings recorded at capture time</li>\\n</ul>\",\"id\":\"docs/pages/sdk/verify.mdx#notes\",\"isPage\":false,\"text\":\"\\n\\nVerification is performed locally—no network required\\nUse verifyBindings() for photos with succinct.bindings (before proof generation)\\nUse verifyProof() for photos with succinct.proof (after proof generation)\\nPhotos with only succinct.bindings will fail verifyProof() (they haven&#x27;t been proven yet)\\nPhotos with succinct.proof can use either verification method, but verifyProof() provides stronger guarantees\\nThe Apple Root CA is pinned in the SDK; proofs must chain to this root\\ncaptureMetadata() provides access to device and camera settings recorded at capture time\\n\",\"title\":\"Notes\",\"titles\":[\"Verify SDK\"]}]}}"

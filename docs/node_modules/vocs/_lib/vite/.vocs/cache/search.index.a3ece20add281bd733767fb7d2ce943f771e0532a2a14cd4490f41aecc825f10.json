05CC5;--shiki-dark:#6CB6FF\\\">14</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> },</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">  overlay: {</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">    ...</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">StyleSheet.absoluteFillObject,</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">    backgroundColor: </span><span style=\\\"color:#032F62;--shiki-dark:#96D0FF\\\">&quot;rgba(0,0,0,0.7)&quot;</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">,</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">    justifyContent: </span><span style=\\\"color:#032F62;--shiki-dark:#96D0FF\\\">&quot;center&quot;</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">,</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">    alignItems: </span><span style=\\\"color:#032F62;--shiki-dark:#96D0FF\\\">&quot;center&quot;</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">,</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">    zIndex: </span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\">1</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">,</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">  },</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">  overlayText: { color: </span><span style=\\\"color:#032F62;--shiki-dark:#96D0FF\\\">&quot;white&quot;</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">, marginTop: </span><span style=\\\"color:#005CC5;--shiki-dark:#6CB6FF\\\">8</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> },</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">});</span></span></code></pre>\\n\",\"id\":\"docs/pages/sdk/picker.mdx#complete-example-with-proving\",\"isPage\":false,\"text\":\"\\n \\n \\n \\n \\n \\n \\n \\n  const { provingClient, isInitializing } = useProver();\\n  const [isProving, setIsProving] = useState(false);\\n \\n  const handleSelect = async (uri: string) =&gt; {\\n    if (!provingClient || isProving) return;\\n \\n    setIsProving(true);\\n    try {\\n      const provenPath = await provingClient.embedProof(uri);\\n      await CameraRoll.saveAsset(provenPath, { album: &quot;ZCAM&quot; });\\n      alert(&quot;Proof generated!&quot;);\\n    } catch (error: any) {\\n      alert(`Error: ${error.message}`);\\n    } finally {\\n      setIsProving(false);\\n    }\\n  };\\n \\n  const renderBadge = (status: AuthenticityStatus) =&gt; {\\n    if (status === AuthenticityStatus.Bindings) {\\n      return 📝;\\n    }\\n    if (status === AuthenticityStatus.Proof) {\\n      return ✓;\\n    }\\n    return null;\\n  };\\n \\n  if (isInitializing) {\\n    return ;\\n  }\\n \\n  return (\\n    \\n      {isProving &amp;&amp; (\\n        \\n          \\n          Generating proof...\\n        \\n      )}\\n      \\n    \\n  );\\n}\\n \\nconst styles = StyleSheet.create({\\n  container: { flex: 1 },\\n  centered: { flex: 1, justifyContent: &quot;center&quot; },\\n  badge: { position: &quot;absolute&quot;, top: 4, right: 4, fontSize: 14 },\\n  overlay: {\\n    ...StyleSheet.absoluteFillObject,\\n    backgroundColor: &quot;rgba(0,0,0,0.7)&quot;,\\n    justifyContent: &quot;center&quot;,\\n    alignItems: &quot;center&quot;,\\n    zIndex: 1,\\n  },\\n  overlayText: { color: &quot;white&quot;, marginTop: 8 },\\n});\\n\",\"title\":\"Complete Example with Proving\",\"titles\":[\"Picker SDK\"]},{\"href\":\"/sdk/picker#permissions\",\"html\":\"\\n\",\"id\":\"docs/pages/sdk/picker.mdx#permissions\",\"isPage\":false,\"text\":\"\\n\",\"title\":\"Permissions\",\"titles\":[\"Picker SDK\"]},{\"href\":\"/sdk/picker#ios\",\"html\":\"\\n<p>Add to <code>Info.plist</code> when using photo gallery source:</p>\\n<pre class=\\\"shiki shiki-themes github-light github-dark-dimmed\\\" style=\\\"background-color:#fff;--shiki-dark-bg:#22272e;color:#24292e;--shiki-dark:#adbac7\\\" tabindex=\\\"0\\\"><code><span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">&lt;</span><span style=\\\"color:#22863A;--shiki-dark:#8DDB8C\\\">key</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">&gt;NSPhotoLibraryUsageDescription&lt;/</span><span style=\\\"color:#22863A;--shiki-dark:#8DDB8C\\\">key</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">&gt;</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">&lt;</span><span style=\\\"color:#22863A;--shiki-dark:#8DDB8C\\\">string</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">&gt;This app needs access to your photos.&lt;/</span><span style=\\\"color:#22863A;--shiki-dark:#8DDB8C\\\">string</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">&gt;</span></span></code></pre>\\n\",\"id\":\"docs/pages/sdk/picker.mdx#ios\",\"isPage\":false,\"text\":\"\\nAdd to Info.plist when using photo gallery source:\\n&lt;key&gt;NSPhotoLibraryUsageDescription&lt;/key&gt;\\n&lt;string&gt;This app needs access to your photos.&lt;/string&gt;\\n\",\"title\":\"iOS\",\"titles\":[\"Picker SDK\",\"Permissions\"]},{\"href\":\"/sdk/picker#android\",\"html\":\"\\n<p>For Android 13+:</p>\\n<ul>\\n<li><code>android.permission.READ_MEDIA_IMAGES</code></li>\\n</ul>\\n<p>For older versions:</p>\\n<ul>\\n<li><code>android.permission.READ_EXTERNAL_STORAGE</code></li>\\n</ul>\\n\",\"id\":\"docs/pages/sdk/picker.mdx#android\",\"isPage\":false,\"text\":\"\\nFor Android 13+:\\n\\nandroid.permission.READ_MEDIA_IMAGES\\n\\nFor older versions:\\n\\nandroid.permission.READ_EXTERNAL_STORAGE\\n\\n\",\"title\":\"Android\",\"titles\":[\"Picker SDK\",\"Permissions\"]},{\"href\":\"/sdk/picker#limitations\",\"html\":\"\\n<ul>\\n<li>Photo gallery source loads the first 20 photos (no pagination)</li>\\n<li>Image list is loaded once on mount; source prop changes require remounting</li>\\n<li>Single selection only</li>\\n<li>Photos only (no videos)</li>\\n<li>You must handle runtime permissions before rendering gallery source</li>\\n</ul>\",\"id\":\"docs/pages/sdk/picker.mdx#limitations\",\"isPage\":false,\"text\":\"\\n\\nPhoto gallery source loads the first 20 photos (no pagination)\\nImage list is loaded once on mount; source prop changes require remounting\\nSingle selection only\\nPhotos only (no videos)\\nYou must handle runtime permissions before rendering gallery source\\n\",\"title\":\"Limitations\",\"titles\":[\"Picker SDK\"]}]}}"

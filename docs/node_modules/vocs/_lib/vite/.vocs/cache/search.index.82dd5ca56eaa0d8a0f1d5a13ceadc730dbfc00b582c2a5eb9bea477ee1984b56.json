\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">  return</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> (</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">    </span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">      </span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">      </span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">      </span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">      </span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">    </span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">  );</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">}</span></span>\\n<span class=\\\"line\\\" data-empty-line=\\\"true\\\"> </span>\\n<span class=\\\"line\\\" data-empty-line=\\\"true\\\"> </span>\\n<span class=\\\"line\\\"><span style=\\\"color:#D73A49;--shiki-dark:#F47067\\\">  return</span><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\"> (</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">    </span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">      </span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">    </span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">  );</span></span>\\n<span class=\\\"line\\\"><span style=\\\"color:#24292E;--shiki-dark:#ADBAC7\\\">}</span></span></code></pre>\\n\",\"id\":\"docs/pages/getting-started/quickstart.mdx#complete-example\",\"isPage\":false,\"text\":\"\\nHere&#x27;s a minimal app combining all three steps:\\n \\n \\n \\n \\n \\n \\nfunction MainScreen() {\\n  const camera = useRef(null);\\n  const [captureInfo, setCaptureInfo] = useState();\\n  const [photoPath, setPhotoPath] = useState&lt;string&gt;();\\n  const [provenPath, setProvenPath] = useState&lt;string&gt;();\\n  const { provingClient } = useProver();\\n \\n  const settings = {\\n    appId: process.env.EXPO_PUBLIC_APP_ID!,\\n    production: false,\\n  };\\n \\n  useEffect(() =&gt; {\\n    initCapture(settings).then(setCaptureInfo);\\n  }, []);\\n \\n  const capture = async () =&gt; {\\n    const photo = await camera.current?.takePhoto();\\n    if (photo) setPhotoPath(photo.path);\\n  };\\n \\n  const prove = async () =&gt; {\\n    if (!provingClient || !photoPath) return;\\n    const path = await provingClient.waitAndEmbedProof(photoPath);\\n    setProvenPath(path);\\n  };\\n \\n  const verify = () =&gt; {\\n    if (!provenPath) return;\\n    const file = new VerifiableFile(provenPath);\\n    const isValid = file.verifyHash() &amp;&amp; file.verifyProof();\\n    alert(isValid ? &quot;Authentic!&quot; : &quot;Invalid&quot;);\\n  };\\n \\n  if (!captureInfo) return Initializing...;\\n \\n  return (\\n    \\n      \\n      \\n      \\n      \\n    \\n  );\\n}\\n \\n \\n  return (\\n    \\n      \\n    \\n  );\\n}\\n\",\"title\":\"Complete Example\",\"titles\":[\"Quickstart\"]},{\"href\":\"/getting-started/quickstart#under-the-hood\",\"html\":\"\\n<ol>\\n<li>\\n<p><strong>Capture</strong>: Takes a photo, generates an App Attest assertion over the photo hash, and embeds a C2PA manifest with <code>succinct.bindings</code>.</p>\\n</li>\\n<li>\\n<p><strong>Prove</strong>: Sends the bindings to the prover backend, which generates an SP1 zero-knowledge proof. The proof is embedded as <code>succinct.proof</code> in the C2PA manifest.</p>\\n</li>\\n<li>\\n<p><strong>Verify</strong>: Recomputes the photo hash, verifies it matches the manifest, and validates the ZK proof against the pinned Apple Root CA.</p>\\n</li>\\n</ol>\",\"id\":\"docs/pages/getting-started/quickstart.mdx#under-the-hood\",\"isPage\":false,\"text\":\"\\n\\n\\nCapture: Takes a photo, generates an App Attest assertion over the photo hash, and embeds a C2PA manifest with succinct.bindings.\\n\\n\\nProve: Sends the bindings to the prover backend, which generates an SP1 zero-knowledge proof. The proof is embedded as succinct.proof in the C2PA manifest.\\n\\n\\nVerify: Recomputes the photo hash, verifies it matches the manifest, and validates the ZK proof against the pinned Apple Root CA.\\n\\n\",\"title\":\"Under the Hood\",\"titles\":[\"Quickstart\"]}]}}"

{
  "name": "@succinctlabs/react-native-zcam1-c2pa",
  "version": "0.2.4",
  "description": "ZCAM1 C2PA SDK",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "codegenConfig": {
    "name": "ReactNativeZcam1C2paSpec",
    "type": "modules",
    "jsSrcsDir": "src"
  },
  "type": "module",
  "files": [
    "src",
    "lib",
    "scripts",
    "android",
    "cpp",
    "ios",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "ReactNativeZcam1C2pa.podspec",
    "Zcam1C2paFramework.xcframework",
    "README.md",
    "turbo.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/succinctlabs/zcam1-sdk.git"
  },
  "author": "leruaa",
  "license": "MIT",
  "homepage": "https://github.com/succinctlabs/zcam1-sdk#readme",
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@react-native/babel-preset": "0.81.1",
    "@types/react": "^19.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "install": "^0.13.0",
    "npm": "^11.6.4",
    "prettier": "^3.4.2",
    "react-native-builder-bob": "^0.40.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.21.0"
  },
  "dependencies": {
    "uniffi-bindgen-react-native": "^0.29.3-1"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-native": ">=0.81"
  },
  "scripts": {
    "ubrn:ios": "CARGO_FEATURE_NO_NEON=1 ubrn build ios --and-generate",
    "ubrn:android": "ubrn build android --and-generate",
    "ubrn:web": "ubrn build web",
    "clean": "rm -rfv cpp/ android/CMakeLists.txt android/src/main/java android/*.cpp ios/ src/generated/",
    "build": "bob build",
    "prepack": "npm run ubrn:ios -- --release && npm run build && if [ -z \"$NPM_CONFIG_REGISTRY\" ]; then mv Zcam1C2paFramework.xcframework Zcam1C2paFramework.xcframework.excluded; fi",
    "preyalcpublish": "mv Zcam1C2paFramework.xcframework.excluded Zcam1C2paFramework.xcframework",
    "postyalcpublish": "mv Zcam1C2paFramework.xcframework Zcam1C2paFramework.xcframework.excluded",
    "postpublish": "if [ -e Zcam1C2paFramework.xcframework.excluded ]; then mv Zcam1C2paFramework.xcframework.excluded Zcam1C2paFramework.xcframework; fi",
    "postinstall": "./scripts/download-framework.sh Zcam1C2paFramework.xcframework",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "create-react-native-library": {
    "languages": "kotlin-objc",
    "type": "turbo-module",
    "version": "0.54.8"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ]
}

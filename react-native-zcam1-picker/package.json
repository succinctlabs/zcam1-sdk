{
  "name": "@succinctlabs/react-native-zcam1-picker",
  "version": "0.2.3",
  "description": "ZCAM1 SDK Image Picker",
  "main": "./lib/module/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/succinctlabs/zcam1-sdk.git"
  },
  "author": "leruaa",
  "license": "MIT",
  "homepage": "https://github.com/succinctlabs/zcam1-sdk#readme",
  "type": "module",
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/react": "^19.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.4.2",
    "react-native-builder-bob": "^0.40.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.21.0"
  },
  "dependencies": {
    "@react-native-camera-roll/camera-roll": "^7.10.2",
    "@shopify/flash-list": "^2.2.0",
    "@succinctlabs/react-native-zcam1-c2pa": "^0.2.3",
    "react-native-create-thumbnail": "^2.2.0",
    "react-native-file-access": "^3.2.0"
  },
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./lib/typescript/src/index.d.ts",
  "scripts": {
    "build": "bob build",
    "prepack": "npm run build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ]
}

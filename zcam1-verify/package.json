{
  "name": "@succinctlabs/zcam1-verify",
  "version": "0.4.0-alpha.1",
  "description": "ZCAM1 Verify SDK for browser and Node.js",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": {
        "types": "./dist/index.node.d.ts",
        "default": "./dist/index.node.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "ubrn:web": "ubrn build web --and-generate",
    "build": "vite build && vite build --config vite.config.node.ts",
    "dev": "vite dev",
    "preview": "vite preview",
    "test": "vitest --browser=chromium --run",
    "test:node": "vitest --config vitest.config.node.ts --run",
    "test:watch": "vitest",
    "test:browser": "vitest --browser=chromium --run",
    "prepack": "npm run ubrn:web -- --release && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/succinctlabs/zcam1-sdk.git"
  },
  "author": "leruaa",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/succinctlabs/zcam1-sdk/issues"
  },
  "homepage": "https://github.com/succinctlabs/zcam1-sdk#readme",
  "peerDependencies": {
    "neverthrow": "^8.2.0"
  },
  "optionalDependencies": {
    "@contentauth/c2pa-node": "^0.5.1"
  },
  "dependencies": {
    "@contentauth/c2pa-web": "^0.5.7",
    "@noble/hashes": "^2.0.1",
    "@peculiar/x509": "^1.14.3",
    "@scure/base": "^2.0.0",
    "@succinctlabs/sp1-wasm-verifier": "^6.0.0",
    "asn1js": "^3.0.7",
    "cbor2": "^2.2.1",
    "json-canonicalize": "^2.0.0",
    "neverthrow": "^8.2.0",
    "uniffi-bindgen-react-native": "^0.30.0-1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@vitest/browser": "^4.1.0",
    "jsdom": "^28.0.0",
    "playwright": "^1.46.0",
    "typescript": "^5.5.4",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  }
}

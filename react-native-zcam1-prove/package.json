{
  "name": "@succinctlabs/react-native-zcam1-prove",
  "version": "0.2.5",
  "description": "ZCAM1 Proving SDK",
  "main": "./lib/module/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/succinctlabs/zcam1-sdk.git"
  },
  "author": "leruaa",
  "license": "MIT",
  "homepage": "https://github.com/succinctlabs/zcam1-sdk.git#readme",
  "type": "module",
  "files": [
    "src",
    "lib",
    "scripts",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "cpp",
    "ios",
    "ReactNativeZcam1Prove.podspec",
    "Zcam1ProveFramework.xcframework",
    "README.md",
    "turbo.json",
    "ubrn.config.yaml"
  ],
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "codegenConfig": {
    "name": "ReactNativeZcam1ProveSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.zcam1prove"
    }
  },
  "create-react-native-library": {
    "languages": "kotlin-objc",
    "type": "turbo-module",
    "tools": [],
    "version": "0.55.1"
  },
  "dependencies": {
    "@scure/base": "^2.0.0",
    "@succinctlabs/react-native-zcam1-c2pa": "^0.2.3",
    "@succinctlabs/react-native-zcam1-common": "^0.2.2",
    "react-native-file-access": "^3.2.0"
  },
  "scripts": {
    "ubrn:checkout": "ubrn checkout",
    "ubrn:ios": "CARGO_FEATURE_NO_NEON=1 ubrn build ios --and-generate",
    "ubrn:android": "ubrn build android --and-generate",
    "ubrn:web": "ubrn build web",
    "clean": "rm -rfv cpp/ android/CMakeLists.txt android/src/main/java android/*.cpp ios/ src/generated/",
    "build": "bob build",
    "prepack": "npm run ubrn:ios -- --release && npm run build && if [ -z $NPM_CONFIG_REGISTRY ]; then  mv Zcam1ProveFramework.xcframework Zcam1ProveFramework.xcframework.excluded; fi",
    "preyalcpublish": "mv Zcam1ProveFramework.xcframework.excluded Zcam1ProveFramework.xcframework",
    "postyalcpublish": "mv Zcam1ProveFramework.xcframework Zcam1ProveFramework.xcframework.excluded",
    "postpublish": "if [ -e Zcam1ProveFramework.xcframework.excluded ]; then mv Zcam1ProveFramework.xcframework.excluded Zcam1ProveFramework.xcframework; fi",
    "postinstall": "./scripts/download-framework.sh Zcam1ProveFramework.xcframework",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.4.2",
    "react-native-builder-bob": "^0.40.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.21.0"
  },
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./lib/typescript/src/index.d.ts",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ]
}

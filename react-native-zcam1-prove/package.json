{
  "name": "react-native-zcam1-prove",
  "version": "0.1.0",
  "description": "ZCAM1 Proving SDK",
  "main": "./lib/module/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/succinctlabs/zcam1-sdk.git"
  },
  "author": "leruaa",
  "license": "MIT",
  "homepage": "https://github.com/succinctlabs/zcam1-sdk.git#readme",
  "type": "module",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "cpp",
    "ios",
    "Zcam1ProveFramework.xcframework/",
    "Zcam1Prove.podspec",
    "README.md",
    "turbo.json",
    "ubrn.config.yaml"
  ],
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "codegenConfig": {
    "name": "Zcam1ProveSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.zcam1prove"
    }
  },
  "create-react-native-library": {
    "languages": "kotlin-objc",
    "type": "turbo-module",
    "tools": [],
    "version": "0.55.1"
  },
  "dependencies": {
    "@scure/base": "^2.0.0",
    "react-native-file-access": "^3.2.0",
    "react-native-zcam1-c2pa": "^0.1.5",
    "zcam1-common": "^0.1.0"
  },
  "scripts": {
    "ubrn:checkout": "ubrn checkout",
    "ubrn:ios": "CARGO_FEATURE_NO_NEON=1 ubrn build ios --and-generate",
    "ubrn:android": "ubrn build android --and-generate",
    "ubrn:web": "ubrn build web",
    "ubrn:clean": "rm -rfv cpp/ android/CMakeLists.txt android/src/main/java android/*.cpp ios/ src/Native* src/index.*ts* src/generated/",
    "prepublish": "CARGO_FEATURE_NO_NEON=1 ubrn build ios --and-generate --release",
    "prepare": "bob build"
  },
  "devDependencies": {
    "react-native-builder-bob": "^0.40.17",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./lib/typescript/src/index.d.ts",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ]
}
